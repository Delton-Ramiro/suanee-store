{
  "name": "ecommerce",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.6.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "cd apps/api && npx prisma studio",
    "postprisma:generate": "[ -L node_modules/@prisma/client/.prisma ] || ln -s ../../.prisma node_modules/@prisma/client/.prisma"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
