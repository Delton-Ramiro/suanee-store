    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/(shop)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(shop)/layout.js"
    ],
    "/(shop)/categorias/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(shop)/categorias/[slug]/page.js"
    ],
    "/(shop)/produtos/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(shop)/produtos/page.js"
    ],
    "/(shop)/categorias/[slug]/produtos/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(shop)/categorias/[slug]/produtos/page.js"
    ],
    "/(shop)/produtos/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(shop)/produtos/[slug]/page.js"
    ]
  }
}