generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum GenderScope {
  women
  men
  kids
  unisex
}

enum Platform {
  web
  ios
  android
}

enum SizeSystem {
  EU
  US
  UK
  IT
  universal
}

enum InputType {
  multi_select
  single_select
  range
  boolean
}

enum MediaType {
  image
  video
}

enum StockStatus {
  in_stock
  by_importation
}

enum OrderStatus {
  pending
  paid
  in_process
  in_transit
  delivered
  returned
  cancelled
}

enum SenderType {
  user
  admin
}

enum MessageMediaType {
  image
  video
}

enum ProductStatus {
  draft
  published
  archived
}

enum BrandStatus {
  draft
  published
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  avatarUrl       String?
  googleId        String?   @unique
  phone           String?
  whatsappNumber  String?
  phoneVerifiedAt DateTime?
  birthDate       DateTime?
  fcmTokens       String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  cart           CartItem[]
  favorites      Favorite[]
  orders         Order[]
  conversations  Conversation[]
  visitorSession VisitorSession?

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model VisitorSession {
  id          String   @id @default(uuid())
  anonymousId String   @unique
  userId      String?  @unique
  firstSeenAt DateTime @default(now()) @map("created_at")
  lastSeenAt  DateTime @updatedAt @map("updated_at")
  platform    Platform

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("visitor_sessions")
}

// ─── Admin Users ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  avatarUrl    String?
  permissions  BigInt    @default(0)
  roleKey      String?   @map("role_key")
  fcmTokens    String[]  @default([])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  auditLogs             AdminAuditLog[]
  processedOrders       Order[]                     @relation("ProcessedBy")
  passwordResetRequests AdminPasswordResetRequest[]

  @@map("admin_users")
}

model AdminPasswordResetRequest {
  id         String   @id @default(uuid())
  adminId    String
  tokenHash  String   @unique
  newPwdHash String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_password_reset_requests")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String?
  changesJson  Json?
  createdAt    DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([resourceType, resourceId])
  @@map("admin_audit_logs")
}

// ─── Categories ──────────────────────────────────────────────────────────────

model Category {
  id          String       @id @default(uuid())
  parentId    String?
  level       Int
  name        String
  slug        String       @unique
  description String?
  imageUrl    String?
  iconUrl     String?
  genderScope GenderScope?
  position    Int          @default(1)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  parent               Category?                     @relation("CategoryTree", fields: [parentId], references: [id])
  children             Category[]                    @relation("CategoryTree")
  products             ProductCategory[]
  attributeDefinitions AttributeDefinitionCategory[]
  brandCategories      BrandCategory[]
  sizeCategories       SizeCategory[]
  mostSearched         MostSearched[]

  @@index([parentId])
  @@index([level])
  @@index([slug])
  @@map("categories")
}

// ─── Brands ──────────────────────────────────────────────────────────────────

model Brand {
  id               String      @id @default(uuid())
  name             String
  slug             String      @unique
  logoUrl          String?
  landingImage1Url String?
  landingImage2Url String?
  status           BrandStatus @default(published)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  products        Product[]
  brandCategories BrandCategory[]

  @@map("brands")
}

model BrandCategory {
  brandId    String
  categoryId String

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([brandId, categoryId])
  @@index([categoryId, brandId])
  @@map("brand_categories")
}

// ─── Collections ─────────────────────────────────────────────────────────────

model Collection {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  coverImageUrl String?
  position      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products ProductCollection[]

  @@map("collections")
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId, productId])
  @@map("product_collections")
}

// ─── Colors ──────────────────────────────────────────────────────────────────

model Color {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  hexCode   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productVariants ProductVariant[]
  productMedia    ProductMedia[]

  @@map("colors")
}

// ─── Sizes ───────────────────────────────────────────────────────────────────

model Size {
  id         String     @id @default(uuid())
  name       String     @unique
  slug       String     @unique
  label      String
  sizeSystem SizeSystem @default(universal)
  position   Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  sizeCategories  SizeCategory[]
  productVariants ProductVariant[]
  productSizes    ProductSize[]

  @@map("sizes")
}

model SizeCategory {
  sizeId     String
  categoryId String
  level      Int

  size     Size     @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([sizeId, categoryId])
  @@index([categoryId, sizeId])
  @@map("size_categories")
}

// ─── Size Guides ─────────────────────────────────────────────────────────────

model SizeGuide {
  id          String   @id @default(uuid())
  name        String
  description String?
  images      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("size_guides")
}

// ─── Attribute Definitions (Dynamic Filters) ─────────────────────────────────

model AttributeDefinition {
  id        String    @id @default(uuid())
  name      String
  slug      String
  inputType InputType @default(multi_select)
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  categories        AttributeDefinitionCategory[]
  options           AttributeOption[]
  productAttributes ProductAttribute[]

  @@index([slug])
  @@map("attribute_definitions")
}

model AttributeDefinitionCategory {
  attributeDefinitionId String
  categoryId            String

  definition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)
  category   Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([attributeDefinitionId, categoryId])
  @@index([categoryId, attributeDefinitionId])
  @@map("attribute_definition_categories")
}

model AttributeOption {
  id                    String @id @default(uuid())
  attributeDefinitionId String
  label                 String
  value                 String
  position              Int    @default(0)

  definition        AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)
  productAttributes ProductAttribute[]

  @@unique([attributeDefinitionId, value])
  @@map("attribute_options")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id                 String        @id @default(uuid())
  brandId            String
  sizeGuideId        String?
  name               String
  slug               String        @unique
  description        String?
  basePrice          Decimal       @db.Decimal(10, 2)
  isIndicativePrice  Boolean       @default(false)
  hasDiscount        Boolean       @default(false)
  discountPrice      Decimal?      @db.Decimal(10, 2)
  stockStatus        StockStatus   @default(in_stock)
  status             ProductStatus @default(draft)
  isVisible          Boolean       @default(true)
  keyCharacteristics String?
  productInfo        String?
  sendPolicy         String?
  returnPolicy       String?
  deliveryEstimate   String?
  supplierLink       String?
  mainColorId        String?
  genderScope        GenderScope?
  metaTitle          String?       @db.VarChar(60)
  metaDescription    String?       @db.VarChar(160)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  brand     Brand      @relation(fields: [brandId], references: [id], onDelete: Restrict)
  sizeGuide SizeGuide? @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull)

  collections   ProductCollection[]
  categories    ProductCategory[]
  variants      ProductVariant[]
  media         ProductMedia[]
  sizes         ProductSize[]
  attributes    ProductAttribute[]
  favorites     Favorite[]
  orderItems    OrderItem[]
  storyProducts StorySlideProduct[]
  suppliers     ProductSupplier[]
  competitors   ProductCompetitor[]
  cartItems     CartItem[]

  @@index([brandId])
  @@index([status, isVisible])
  @@index([createdAt])
  @@map("products")
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([productId, categoryId])
  @@index([categoryId, productId])
  @@map("product_categories")
}

model ProductVariant {
  id                String   @id @default(uuid())
  productId         String
  colorId           String
  sizeId            String
  sku               String   @unique
  stockQuantity     Int      @default(0)
  price             Decimal? @db.Decimal(10, 2)
  hasDiscount       Boolean  @default(false)
  discountPrice     Decimal? @db.Decimal(10, 2)
  isIndicativePrice Boolean  @default(false)
  position          Int      @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  color      Color       @relation(fields: [colorId], references: [id], onDelete: Restrict)
  size       Size        @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, colorId, sizeId])
  @@index([productId])
  @@map("product_variants")
}

model ProductMedia {
  id        String    @id @default(uuid())
  productId String
  colorId   String?
  url       String
  mediaType MediaType
  position  Int       @default(0)
  isPrimary Boolean   @default(false)
  isDeleted Boolean   @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color?  @relation(fields: [colorId], references: [id], onDelete: SetNull)

  @@index([productId, colorId])
  @@map("product_media")
}

model ProductSize {
  productId String
  sizeId    String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    Size    @relation(fields: [sizeId], references: [id], onDelete: Restrict)

  @@id([productId, sizeId])
  @@map("product_sizes")
}

model ProductAttribute {
  productId             String
  attributeDefinitionId String
  attributeOptionId     String

  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)
  option     AttributeOption     @relation(fields: [attributeOptionId], references: [id], onDelete: Restrict)

  @@id([productId, attributeDefinitionId, attributeOptionId])
  @@index([productId])
  @@map("product_attributes")
}

// ─── Financial Analysis (Admin-Only) ─────────────────────────────────────────

model ProductSupplier {
  id                String   @id @default(uuid())
  productId         String
  supplierName      String
  supplierLink      String?
  address           String?
  contact           String?
  currencyRateId    String?
  supplierPrice     Decimal  @db.Decimal(10, 2)
  priceWithDelivery Decimal  @db.Decimal(10, 2)
  deliveryTax       Decimal  @db.Decimal(10, 2)
  otherCosts        Decimal  @db.Decimal(10, 2)
  proposedPrice     Decimal? @db.Decimal(10, 2)
  isDefault         Boolean  @default(false)
  notes             String?

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  currencyRate CurrencyRate? @relation(fields: [currencyRateId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([productId, isDefault])
  @@map("product_suppliers")
}

model ProductCompetitor {
  id        String  @id @default(uuid())
  productId String
  name      String?
  link      String
  price     Decimal @db.Decimal(10, 2)
  comments  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_competitors")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model CartItem {
  id               String   @id @default(uuid())
  userId           String
  productId        String
  productVariantId String
  quantity         Int      @default(1)
  addedAt          DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([userId, productVariantId])
  @@index([userId])
  @@map("cart_items")
}

// ─── Favorites ────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                 String      @id @default(uuid())
  conversationId     String
  userId             String
  processedById      String?
  status             OrderStatus @default(pending)
  proofNotes         String?
  returnReason       String?
  returnProof        String?
  cancellationReason String?
  subtotal           Decimal     @db.Decimal(10, 2)
  shippingCost       Decimal     @default(0) @db.Decimal(10, 2)
  total              Decimal     @db.Decimal(10, 2)
  bruteMargin        Decimal     @default(0) @db.Decimal(10, 2)
  paidAt             DateTime?
  inProcessAt        DateTime?
  inTransitAt        DateTime?
  deliveredAt        DateTime?
  returnedAt         DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  processedBy  AdminUser?   @relation("ProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  items        OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
  @@index([deliveredAt])
  @@index([returnedAt])
  @@index([cancelledAt])
  @@index([userId, createdAt])
  @@map("orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  orderId          String
  productId        String
  productVariantId String
  quantity         Int
  unitPrice        Decimal @db.Decimal(10, 2)
  bruteMargin      Decimal @default(0) @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}

// ─── Conversations & Chat ─────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages Message[]
  orders   Order[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String            @id @default(uuid())
  conversationId String
  senderId       String
  senderType     SenderType
  content        String?
  mediaUrl       String?
  mediaType      MessageMediaType?
  isRead         Boolean           @default(false)
  createdAt      DateTime          @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, isRead])
  @@map("messages")
}

// ─── Stories ─────────────────────────────────────────────────────────────────

model Story {
  id           String    @id @default(uuid())
  name         String
  thumbnailUrl String?
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  position     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  slides StorySlide[]

  @@map("stories")
}

model StorySlide {
  id        String    @id @default(uuid())
  storyId   String
  mediaUrl  String
  mediaType MediaType
  position  Int       @default(0)
  createdAt DateTime  @default(now())

  story    Story               @relation(fields: [storyId], references: [id], onDelete: Cascade)
  products StorySlideProduct[]

  @@index([storyId])
  @@map("story_slides")
}

model StorySlideProduct {
  storySlideId String
  productId    String

  slide   StorySlide @relation(fields: [storySlideId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([storySlideId, productId])
  @@map("story_slide_products")
}

// ─── Most Searched ────────────────────────────────────────────────────────────

model MostSearched {
  id         String   @id @default(uuid())
  categoryId String
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([position])
  @@map("most_searched")
}

// ─── Currency Rates ───────────────────────────────────────────────────────────

model CurrencyRate {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  symbol    String
  rate      Decimal  @db.Decimal(10, 4)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  suppliers ProductSupplier[]

  @@map("currency_rates")
}
